generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  PAID
  ACCEPTED
  COMPLETED
  REJECTED
}

enum ConsultationMode {
  VIDEO
  AUDIO
  IN_PERSON
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())

  doctorProfile       Doctor?
  patientProfile      PatientProfile?
  familyMembers       FamilyMember[]
  patientAppointments Appointment[]   @relation("PatientAppointments")
  doctorAppointments  Appointment[]   @relation("DoctorAppointments")
  patientReviews      Review[]        @relation("PatientReviews")
  invitedAppointments InvitedDoctor[] @relation("InvitedDoctor")
  doctorNotes         DoctorNote[]    @relation("DoctorNote")
  workingHours        DoctorWorkingHour[] @relation("DoctorWorkingHours")
  workingHourOverrides DoctorWorkingHourOverride[] @relation("DoctorWorkingHourOverrides")
  slots               DoctorSlot[]        @relation("DoctorSlots")
}

model PatientProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profilePictureUrl     String?
  givenName             String?
  secondaryName         String?
  familyName            String?
  noFamilyName          Boolean  @default(false)
  relation              String?
  gender                String?
  dateOfBirth           String?
  phoneCode             String?  @default("+61")
  phone                 String?
  email                 String?
  address               String?
  ctgIslandOrigin       String?
  allergies             String?
  medicareCardNumber    String?
  medicareIrn           String?
  dvaCardNumber         String?
  dvaCardColor          String?
  currentGpName         String?
  currentGpEmail        String?
  partnerCode           String?
  noCurrentGpDetails    Boolean  @default(false)
  healthIdentifierType  String?  @default("Medicare Number")
  saveHealthIdentifier  Boolean  @default(false)
  onBehalfOfFamilyMember Boolean @default(false)
  patientConsentGiven   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model FamilyMember {
  id        String   @id @default(uuid())
  patientId String
  patient   User     @relation(fields: [patientId], references: [id])
  name      String
  relation  String
  age       Int
  gender    String?
  createdAt DateTime @default(now())

  appointments Appointment[]
}

model Specialization {
  id      String   @id @default(uuid())
  name    String   @unique
  doctors Doctor[]
}

model Doctor {
  userId           String         @id
  user             User           @relation(fields: [userId], references: [id])
  specializationId String
  specialization   Specialization @relation(fields: [specializationId], references: [id])
  fee              Decimal
  isOnline         Boolean        @default(false)
  averageRating    Float          @default(0)
  reviewCount      Int            @default(0)
  showOnlineOnLogin Boolean       @default(true)
  givenName        String?
  secondaryName    String?
  familyName       String?
  noFamilyName     Boolean        @default(false)
  gender           String?
  dateOfBirth      String?
  phoneCode        String?        @default("+91")
  phone            String?
  address          String?
  experienceRange  String?
  qualification    String?
  practitionerType String?
  services         String?
  about            String?
  ahpraNumber      String?
  prescriberNumber String?
  providerNumber   String?
  hpiIndividualNumber String?
  hpioNumber       String?
  saveMyHINumber   Boolean        @default(true)
  mimsUserId       String?
  mimsEulaAccepted Boolean        @default(false)
  mimsTermsAccepted Boolean       @default(false)
  prescriptionEntityId String?
  prescriptionAccessEnabled Boolean @default(true)
  accountHolderName String?
  accountNumber    String?
  routingNumber    String?
  autoDraftNotesEnabled Boolean   @default(false)
  otpDeliveryChannel String       @default("BOTH")
  slotDurationMinutesVideo Int    @default(30)
  slotDurationMinutesAudio Int    @default(20)
  slotDurationMinutesInPerson Int @default(40)

  reviews          Review[]
}

model Appointment {
  id             String  @id @default(uuid())
  patientId      String
  doctorId       String
  familyMemberId String?
  status         String // PENDING, ACCEPTED, REJECTED, COMPLETED, CANCELLED
  declineReason  String?

  // Scheduling & Payment fields
  type            String    @default("ON_DEMAND") // ON_DEMAND, SCHEDULED
  consultationMode ConsultationMode @default(VIDEO)
  scheduledFor    DateTime?
  scheduledUntil  DateTime?
  paymentStatus   String    @default("PENDING") // PENDING, PAID, FAILED
  stripeSessionId String?

  aiSummary Json? // { symptoms, severity, duration }

  patient      User          @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor       User          @relation("DoctorAppointments", fields: [doctorId], references: [id])
  familyMember FamilyMember? @relation(fields: [familyMemberId], references: [id])

  consultation   Consultation?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  messages       Message[]
  invitedDoctors InvitedDoctor[]
  doctorNotes    DoctorNote[]
  slot           DoctorSlot?
  review         Review?

  @@index([doctorId, scheduledFor])
}

model DoctorWorkingHour {
  id           String   @id @default(uuid())
  doctorId     String
  consultationMode ConsultationMode @default(VIDEO)
  dayOfWeek    Int // 0 = Sunday, 6 = Saturday
  segmentIndex Int // order for split shifts in same day
  startMinutes Int // minutes from midnight, e.g. 540 = 09:00
  endMinutes   Int // minutes from midnight, e.g. 1020 = 17:00
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctor User @relation("DoctorWorkingHours", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, consultationMode, dayOfWeek, segmentIndex])
  @@index([doctorId, consultationMode])
}

model DoctorWorkingHourOverride {
  id           String   @id @default(uuid())
  doctorId     String
  consultationMode ConsultationMode @default(VIDEO)
  date         DateTime
  segmentIndex Int
  startMinutes Int
  endMinutes   Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctor User @relation("DoctorWorkingHourOverrides", fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, consultationMode, date, segmentIndex])
  @@index([doctorId, consultationMode, date])
}

model DoctorSlot {
  id            String    @id @default(uuid())
  doctorId      String
  startAt       DateTime
  endAt         DateTime
  appointmentId String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  doctor      User         @relation("DoctorSlots", fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@unique([doctorId, startAt])
  @@index([doctorId, startAt])
}

model Consultation {
  id              String      @id @default(uuid())
  appointmentId   String      @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  notes           String?
  prescription    Json?
  prescriptionUrl String?
  updatedAt       DateTime    @updatedAt
}

model Message {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  senderId      String
  senderRole    Role
  text          String
  createdAt     DateTime    @default(now())
}

model InvitedDoctor {
  id            String   @id @default(uuid())
  appointmentId String
  doctorId      String
  status        String   @default("PENDING") // PENDING, JOINED, COMPLETED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      User        @relation("InvitedDoctor", fields: [doctorId], references: [id])

  @@unique([appointmentId, doctorId])
  @@index([appointmentId])
  @@index([doctorId])
}

model DoctorNote {
  id            String   @id @default(uuid())
  appointmentId String
  doctorId      String
  notes         String?
  prescription  Json? // [{ name, dosage, frequency, duration }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      User        @relation("DoctorNote", fields: [doctorId], references: [id])

  @@unique([appointmentId, doctorId])
  @@index([appointmentId])
  @@index([doctorId])
}

model Review {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  patientId     String
  doctorId      String
  rating        Int
  message       String?
  isVisible     Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient       User        @relation("PatientReviews", fields: [patientId], references: [id], onDelete: Cascade)
  doctor        Doctor      @relation(fields: [doctorId], references: [userId], onDelete: Cascade)

  @@index([doctorId, createdAt])
  @@index([patientId, createdAt])
  @@index([rating])
}
