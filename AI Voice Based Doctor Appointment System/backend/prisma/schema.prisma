generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  PENDING
  PAID
  ACCEPTED
  COMPLETED
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())

  doctorProfile       Doctor?
  familyMembers       FamilyMember[]
  patientAppointments Appointment[]   @relation("PatientAppointments")
  doctorAppointments  Appointment[]   @relation("DoctorAppointments")
  invitedAppointments InvitedDoctor[] @relation("InvitedDoctor")
  doctorNotes         DoctorNote[]    @relation("DoctorNote")
}

model FamilyMember {
  id        String   @id @default(uuid())
  patientId String
  patient   User     @relation(fields: [patientId], references: [id])
  name      String
  relation  String
  age       Int
  gender    String?
  createdAt DateTime @default(now())

  appointments Appointment[]
}

model Specialization {
  id      String   @id @default(uuid())
  name    String   @unique
  doctors Doctor[]
}

model Doctor {
  userId           String         @id
  user             User           @relation(fields: [userId], references: [id])
  specializationId String
  specialization   Specialization @relation(fields: [specializationId], references: [id])
  fee              Decimal
  isOnline         Boolean        @default(false)
}

model Appointment {
  id             String  @id @default(uuid())
  patientId      String
  doctorId       String
  familyMemberId String?
  status         String // PENDING, ACCEPTED, REJECTED, COMPLETED

  // Scheduling & Payment fields
  type            String    @default("ON_DEMAND") // ON_DEMAND, SCHEDULED
  scheduledFor    DateTime?
  paymentStatus   String    @default("PENDING") // PENDING, PAID, FAILED
  stripeSessionId String?

  aiSummary Json? // { symptoms, severity, duration }

  patient      User          @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor       User          @relation("DoctorAppointments", fields: [doctorId], references: [id])
  familyMember FamilyMember? @relation(fields: [familyMemberId], references: [id])

  consultation   Consultation?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  messages       Message[]
  invitedDoctors InvitedDoctor[]
  doctorNotes    DoctorNote[]
}

model Consultation {
  id              String      @id @default(uuid())
  appointmentId   String      @unique
  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  notes           String?
  prescription    Json?
  prescriptionUrl String?
  updatedAt       DateTime    @updatedAt
}

model Message {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  senderId      String
  senderRole    Role
  text          String
  createdAt     DateTime    @default(now())
}

model InvitedDoctor {
  id            String   @id @default(uuid())
  appointmentId String
  doctorId      String
  status        String   @default("PENDING") // PENDING, JOINED, COMPLETED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      User        @relation("InvitedDoctor", fields: [doctorId], references: [id])

  @@unique([appointmentId, doctorId])
  @@index([appointmentId])
  @@index([doctorId])
}

model DoctorNote {
  id            String   @id @default(uuid())
  appointmentId String
  doctorId      String
  notes         String?
  prescription  Json? // [{ name, dosage, frequency, duration }]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      User        @relation("DoctorNote", fields: [doctorId], references: [id])

  @@unique([appointmentId, doctorId])
  @@index([appointmentId])
  @@index([doctorId])
}
